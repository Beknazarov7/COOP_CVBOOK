{
    "build": {
      "builder": "DOCKERFILE"
    },
    "deploy": {
      "startCommand": "python manage.py migrate && gunicorn CVBOOK.wsgi:application --bind 0.0.0.0:$PORT --workers 3",
      "healthcheckPath": "/health/",
      "healthcheckTimeout": 100,
      "restartPolicyType": "ON_FAILURE",
      "restartPolicyMaxRetries": 10
    }
  }