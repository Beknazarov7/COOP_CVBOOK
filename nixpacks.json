{
  "phases": {
    "setup": {
      "nixPkgs": ["python310", "postgresql", "texlive.combined.scheme-small"]
    },
    "install": {
      "cmds": [
        "apt-get update && apt-get install -y texlive-latex-base texlive-latex-extra texlive-fonts-recommended",
        "pip install --upgrade pip",
        "pip install -r requirements.txt"
      ]
    },
    "build": {
      "cmds": [
        "python manage.py collectstatic --noinput"
      ]
    }
  },
  "start": {
    "cmd": "python manage.py migrate && gunicorn CVBOOK.wsgi:application --bind 0.0.0.0:$PORT --workers 4"
  }
}



